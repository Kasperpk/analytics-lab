# ───────────────────────────────────────────────────────────────
# profiles.yml  –  Copy to ~/.dbt/profiles.yml (or keep in-repo
# via --profiles-dir .) and fill in the real values.
#
# Secrets should come from environment variables; see .env.example.
# ───────────────────────────────────────────────────────────────

analytics_project:
  target: dev                     # default target (override with --target)

  outputs:
    # ── Local development (DuckDB) ──────────────────────────────
    dev:
      type: duckdb
      path: ../../data/warehouse.duckdb
      schema: main
      threads: 4

    # ── CI / automated tests (DuckDB in-memory) ────────────────
    ci:
      type: duckdb
      path: ":memory:"
      schema: main
      threads: 4

    # ── PostgreSQL (mid-tier / self-hosted) ─────────────────────
    postgres:
      type: postgres
      host: "{{ env_var('DBT_POSTGRES_HOST', 'localhost') }}"
      port: "{{ env_var('DBT_POSTGRES_PORT', '5432') | int }}"
      user: "{{ env_var('DBT_POSTGRES_USER', 'analytics') }}"
      password: "{{ env_var('DBT_POSTGRES_PASSWORD') }}"
      dbname: "{{ env_var('DBT_POSTGRES_DBNAME', 'analytics') }}"
      schema: main
      threads: 4

    # ── Databricks (staging) ────────────────────────────────────
    staging:
      type: databricks
      host: "{{ env_var('DBT_DATABRICKS_HOST') }}"
      http_path: "{{ env_var('DBT_DATABRICKS_HTTP_PATH') }}"
      token: "{{ env_var('DBT_DATABRICKS_TOKEN') }}"
      catalog: staging
      schema: main
      threads: 4

    # ── Databricks (production) ─────────────────────────────────
    prod:
      type: databricks
      host: "{{ env_var('DBT_DATABRICKS_HOST') }}"
      http_path: "{{ env_var('DBT_DATABRICKS_HTTP_PATH') }}"
      token: "{{ env_var('DBT_DATABRICKS_TOKEN') }}"
      catalog: production
      schema: main
      threads: 4
