# ───────────────────────────────────────────────────────────────
# Environment variables consumed by profiles.yml
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ───────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────────
DBT_POSTGRES_HOST=localhost
DBT_POSTGRES_PORT=5432
DBT_POSTGRES_USER=analytics
DBT_POSTGRES_PASSWORD=changeme
DBT_POSTGRES_DBNAME=analytics

# ── Databricks ──────────────────────────────────────────────────
DBT_DATABRICKS_HOST=adb-xxxx.azuredatabricks.net
DBT_DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxx
DBT_DATABRICKS_TOKEN=dapi_xxxx
